<html>
<head>
<meta http-equiv="x-ua-compatible" content="ie=9">
<title>Claude Remote Autostart - Installer</title>
<HTA:APPLICATION
    ID="installer"
    APPLICATIONNAME="Claude Remote Autostart"
    BORDER="thin"
    BORDERSTYLE="normal"
    CAPTION="yes"
    ICON="none"
    MAXIMIZEBUTTON="no"
    MINIMIZEBUTTON="yes"
    SCROLL="no"
    SINGLEINSTANCE="yes"
    SYSMENU="yes"
    WINDOWSTATE="normal"
/>
<style>
    * { margin: 0; padding: 0; }

    body {
        font-family: 'Segoe UI', Tahoma, sans-serif;
        background: #0d1117;
        color: #e6edf3;
        font-size: 13px;
    }

    #header {
        background: #161b22;
        border-bottom: 1px solid #30363d;
        padding: 20px 28px 16px;
        text-align: center;
    }

    #header .logo {
        font-size: 22px;
        font-weight: bold;
        color: #e6edf3;
    }

    #header .logo-accent { color: #58a6ff; }

    #header .subtitle {
        margin-top: 4px;
        font-size: 11px;
        color: #6e7681;
    }

    #dots {
        padding: 14px 28px 0;
        height: 24px;
    }

    .dot {
        display: inline-block;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #30363d;
        margin-right: 5px;
    }

    .dot-active { background: #58a6ff; }
    .dot-done   { background: #3fb950; }

    #content {
        padding: 16px 28px 12px;
    }

    .screen { display: none; }
    .screen-active { display: block; }

    .screen-title {
        font-size: 15px;
        font-weight: bold;
        margin-bottom: 5px;
        color: #e6edf3;
    }

    .screen-desc {
        font-size: 12px;
        color: #8b949e;
        line-height: 1.5;
        margin-bottom: 16px;
    }

    .badge {
        font-size: 10px;
        padding: 1px 7px;
        background: #1c2128;
        border: 1px solid #30363d;
        color: #6e7681;
    }

    .check-row {
        padding: 10px 14px;
        background: #161b22;
        border: 1px solid #30363d;
        margin-bottom: 8px;
    }

    .check-label {
        font-size: 12px;
        color: #c9d1d9;
    }

    .check-status {
        float: right;
        font-size: 11px;
        color: #6e7681;
    }

    .status-ok      { color: #3fb950; }
    .status-fail    { color: #f85149; }
    .status-wait    { color: #d29922; }

    .alert {
        padding: 10px 14px;
        font-size: 12px;
        margin-top: 10px;
        border: 1px solid #30363d;
        display: none;
        line-height: 1.5;
    }

    .alert-error   { background: #2d1b1b; border-color: #f85149; color: #ffa198; display: block; }
    .alert-warning { background: #2d2616; border-color: #d29922; color: #e3b341; display: block; }
    .alert-success { background: #1b2d1b; border-color: #3fb950; color: #56d364; display: block; }

    .field-label {
        font-size: 12px;
        font-weight: bold;
        color: #c9d1d9;
        display: block;
        margin-bottom: 6px;
    }

    .field-hint {
        font-size: 11px;
        color: #6e7681;
        margin-bottom: 8px;
    }

    .field-hint a {
        color: #58a6ff;
        text-decoration: underline;
        cursor: pointer;
    }

    input {
        width: 100%;
        padding: 8px 12px;
        background: #161b22;
        border: 1px solid #30363d;
        color: #e6edf3;
        font-size: 12px;
        font-family: 'Segoe UI', Tahoma, sans-serif;
    }

    .skip-link {
        font-size: 11px;
        color: #6e7681;
        cursor: pointer;
        text-decoration: underline;
        display: block;
        margin-top: 10px;
    }

    .success-block {
        text-align: center;
        padding: 10px 0 16px;
    }

    .success-icon {
        font-size: 36px;
        color: #3fb950;
        margin-bottom: 8px;
    }

    .success-title {
        font-size: 18px;
        font-weight: bold;
        color: #3fb950;
        margin-bottom: 8px;
    }

    .success-desc {
        font-size: 12px;
        color: #8b949e;
        line-height: 1.6;
    }

    .info-row {
        padding: 8px 14px;
        background: #161b22;
        border: 1px solid #30363d;
        margin-top: 10px;
        font-size: 11px;
    }

    .info-key { color: #6e7681; }
    .info-val { color: #c9d1d9; font-family: monospace; float: right; }

    #footer {
        padding: 12px 28px;
        border-top: 1px solid #30363d;
        background: #161b22;
        text-align: right;
    }

    .btn {
        padding: 7px 18px;
        font-size: 12px;
        font-weight: bold;
        cursor: pointer;
        border: none;
        font-family: 'Segoe UI', Tahoma, sans-serif;
        margin-left: 8px;
    }

    .btn-primary  { background: #238636; color: #fff; }
    .btn-secondary{ background: #21262d; color: #c9d1d9; border: 1px solid #30363d; }
    .btn-blue     { background: #1f6feb; color: #fff; }

    .btn:disabled { opacity: 0.4; cursor: default; }
</style>
</head>
<body>

<div id="header">
    <div class="logo">Claude <span class="logo-accent">Remote</span> Autostart</div>
    <div class="subtitle">Installer &middot; v1.0.0</div>
</div>

<div id="dots">
    <span class="dot dot-active" id="dot0"></span>
    <span class="dot" id="dot1"></span>
    <span class="dot" id="dot2"></span>
    <span class="dot" id="dot3"></span>
</div>

<div id="content">

    <!-- SCREEN 0: Requirements -->
    <div class="screen screen-active" id="screen0">
        <div class="screen-title" id="welcomeTitle">Requirements</div>
        <div class="screen-desc" id="welcomeDesc">Checking your system before installation.</div>

        <div class="check-row" id="rowClaude">
            <span class="check-label">Claude Code installed</span>
            <span class="check-status status-wait" id="stClaude">Checking...</span>
            <div style="clear:both"></div>
        </div>
        <div class="check-row" id="rowLogin">
            <span class="check-label">Logged in to Claude</span>
            <span class="check-status status-wait" id="stLogin">Checking...</span>
            <div style="clear:both"></div>
        </div>
        <div class="check-row" id="rowTrust">
            <span class="check-label">Workspace trusted</span>
            <span class="check-status status-wait" id="stTrust">Checking...</span>
            <div style="clear:both"></div>
        </div>

        <div class="alert" id="alertWelcome"></div>
    </div>

    <!-- SCREEN 1: Slack -->
    <div class="screen" id="screen1">
        <div class="screen-title">Slack Notifications <span class="badge">optional</span></div>
        <div class="screen-desc">
            Receive the remote session URL on Slack whenever the service starts.<br>
            Already installed &mdash; this step is optional and can be skipped.
        </div>

        <label class="field-label">Incoming Webhook URL</label>
        <div class="field-hint">
            Don't have one? Create your app at
            <a onclick="openSlack()">api.slack.com/apps</a>
        </div>
        <input type="text" id="webhookInput" placeholder="https://hooks.slack.com/services/..." />
        <span class="skip-link" onclick="skipSlack()">Skip, configure later</span>
    </div>

    <!-- SCREEN 2: Installing -->
    <div class="screen" id="screen2">
        <div class="screen-title">Installing...</div>
        <div class="screen-desc">Copying files and configuring Windows Startup.</div>

        <div class="check-row">
            <span class="check-label">Copying files</span>
            <span class="check-status" id="stFiles">Waiting...</span>
            <div style="clear:both"></div>
        </div>
        <div class="check-row">
            <span class="check-label">Windows Startup shortcut</span>
            <span class="check-status" id="stStartup">Waiting...</span>
            <div style="clear:both"></div>
        </div>
        <div class="check-row">
            <span class="check-label">Slack webhook</span>
            <span class="check-status" id="stSlack">Waiting...</span>
            <div style="clear:both"></div>
        </div>

        <div class="alert" id="alertInstall"></div>
    </div>

    <!-- SCREEN 3: Done -->
    <div class="screen" id="screen3">
        <div class="success-block">
            <div class="success-icon">OK</div>
            <div class="success-title">Installation complete!</div>
            <div class="success-desc">
                Claude Remote Autostart will launch automatically<br>
                every time Windows starts.
            </div>
        </div>
        <div class="info-row">
            <span class="info-key">Installed at</span>
            <span class="info-val" id="installPathLabel"></span>
            <div style="clear:both"></div>
        </div>
        <div class="info-row" id="slackRow" style="display:none">
            <span class="info-key">Slack webhook</span>
            <span class="info-val">Configured</span>
            <div style="clear:both"></div>
        </div>
    </div>

</div>

<div id="footer">
    <button class="btn btn-secondary" id="btnBack" onclick="goBack()" style="display:none">Back</button>
    <button class="btn btn-primary" id="btnNext" onclick="goNext()">Check &rarr;</button>
</div>

<script language="VBScript">
Dim WshShell, fso
Set WshShell = CreateObject("WScript.Shell")
Set fso = CreateObject("Scripting.FileSystemObject")

Dim userHome, installDir, scriptDir, startupPath
userHome    = WshShell.ExpandEnvironmentStrings("%USERPROFILE%")
installDir  = userHome & "\claude-remote"
scriptDir   = fso.GetParentFolderName(window.location.pathname)
startupPath = WshShell.SpecialFolders("Startup")

Dim claudePath
claudePath = userHome & "\.local\bin\claude.exe"

Dim alreadyInstalled
alreadyInstalled = fso.FileExists(installDir & "\claude-remote.vbs")

Dim slackWebhook
slackWebhook = ""

Dim currentScreen
currentScreen = 0

Dim checksOk
checksOk = False

Sub Window_OnLoad()
    window.resizeTo 480, 500
    window.moveTo (screen.width - 480) \ 2, (screen.height - 500) \ 2

    If alreadyInstalled Then
        document.getElementById("welcomeTitle").innerText = "Update Installation"
        document.getElementById("welcomeDesc").innerText = "Claude Remote is already installed. This will update your files."
    End If

    RunChecks()
End Sub

Sub RunChecks()
    ' --- Check 1: Claude installed (instant, no process needed) ---
    If Not fso.FileExists(claudePath) Then
        SetStatus "stClaude", "Not found", "fail"
        SetStatus "stLogin", "Skipped", "wait"
        SetStatus "stTrust", "Skipped", "wait"
        ShowAlert "alertWelcome", "error", "Claude Code not found." & vbCrLf & "Install it from claude.ai/code and re-run this installer."
        document.getElementById("btnNext").disabled = True
        Exit Sub
    End If
    SetStatus "stClaude", "Found", "ok"

    ' --- Check 2: Logged in (run claude --version to a temp file) ---
    Dim tmpOut
    tmpOut = userHome & "\claude-remote-check.tmp"
    On Error Resume Next
    If fso.FileExists(tmpOut) Then fso.DeleteFile tmpOut
    On Error GoTo 0

    WshShell.Run "cmd /c """ & claudePath & """ --version > """ & tmpOut & """ 2>&1", 0, True

    Dim output
    output = ""
    On Error Resume Next
    If fso.FileExists(tmpOut) Then
        Dim ts
        Set ts = fso.OpenTextFile(tmpOut, 1)
        output = LCase(ts.ReadAll())
        ts.Close
        fso.DeleteFile tmpOut
    End If
    On Error GoTo 0

    If InStr(output, "not logged") > 0 Or (InStr(output, "login") > 0 And InStr(output, "claude") = 0) Then
        SetStatus "stLogin", "Not logged in", "fail"
        SetStatus "stTrust", "Skipped", "wait"
        ShowAlert "alertWelcome", "error", "Claude Code is not logged in." & vbCrLf & "Open a terminal and run: claude login"
        document.getElementById("btnNext").disabled = True
        Exit Sub
    End If
    SetStatus "stLogin", "OK", "ok"

    ' --- Check 3: Workspace trust (read .claude.json directly, no process) ---
    Dim clauJson
    clauJson = userHome & "\.claude.json"
    Dim trusted
    trusted = False
    On Error Resume Next
    If fso.FileExists(clauJson) Then
        Dim tsJ
        Set tsJ = fso.OpenTextFile(clauJson, 1)
        Dim jContent
        jContent = tsJ.ReadAll()
        tsJ.Close
        ' Check if home folder has hasTrustDialogAccepted: true
        ' Look for the userHome key with forward slashes followed by hasTrustDialogAccepted true
        Dim userHomeSlash
        userHomeSlash = Replace(userHome, "\", "/")
        Dim pos
        pos = InStr(jContent, userHomeSlash)
        If pos > 0 Then
            Dim block
            block = Mid(jContent, pos, 300)
            If InStr(block, """hasTrustDialogAccepted"": true") > 0 Then
                trusted = True
            End If
        End If
    End If
    On Error GoTo 0

    If Not trusted Then
        SetStatus "stTrust", "Not trusted", "fail"
        ShowAlert "alertWelcome", "warning", "Workspace not trusted." & vbCrLf & "Open a terminal, go to your home folder, run 'claude' and accept the trust dialog. Then re-run this installer."
        document.getElementById("btnNext").disabled = True
        Exit Sub
    End If
    SetStatus "stTrust", "Trusted", "ok"

    checksOk = True
    document.getElementById("btnNext").disabled = False
    If alreadyInstalled Then LoadExistingWebhook()
End Sub

Sub LoadExistingWebhook()
    On Error Resume Next
    Dim ts, content, lines, i, val
    Set ts = fso.OpenTextFile(installDir & "\claude-remote.vbs", 1)
    content = ts.ReadAll()
    ts.Close
    lines = Split(content, vbLf)
    For i = 0 To UBound(lines)
        If InStr(lines(i), "slackWebhook =") > 0 And InStr(lines(i), "YOUR_SLACK_WEBHOOK_URL") = 0 Then
            val = Trim(lines(i))
            val = Mid(val, InStr(val, Chr(34)) + 1)
            val = Left(val, Len(val) - 1)
            If InStr(val, "hooks.slack.com") > 0 Then
                document.getElementById("webhookInput").value = val
            End If
        End If
    Next
    On Error GoTo 0
End Sub

Sub goNext()
    If currentScreen = 0 And checksOk Then
        ShowScreen 1
    ElseIf currentScreen = 1 Then
        slackWebhook = Trim(document.getElementById("webhookInput").value)
        ShowScreen 2
        window.setTimeout "RunInstall()", 300
    ElseIf currentScreen = 3 Then
        window.close()
    End If
End Sub

Sub goBack()
    If currentScreen = 1 Then ShowScreen 0
End Sub

Sub skipSlack()
    slackWebhook = ""
    ShowScreen 2
    window.setTimeout "RunInstall()", 300
End Sub

Sub ShowScreen(n)
    Dim i
    For i = 0 To 3
        document.getElementById("screen" & i).className = "screen"
        document.getElementById("dot" & i).className = "dot"
    Next
    document.getElementById("screen" & n).className = "screen screen-active"

    For i = 0 To n - 1
        document.getElementById("dot" & i).className = "dot dot-done"
    Next
    document.getElementById("dot" & n).className = "dot dot-active"

    currentScreen = n

    Select Case n
        Case 0
            document.getElementById("btnBack").style.display = "none"
            document.getElementById("btnNext").innerText = "Check" & Chr(160) & Chr(8594)
            document.getElementById("btnNext").className = "btn btn-primary"
            document.getElementById("btnNext").disabled = Not checksOk
        Case 1
            document.getElementById("btnBack").style.display = "inline"
            document.getElementById("btnNext").innerText = "Install" & Chr(160) & Chr(8594)
            document.getElementById("btnNext").className = "btn btn-primary"
            document.getElementById("btnNext").disabled = False
        Case 2
            document.getElementById("btnBack").style.display = "none"
            document.getElementById("btnNext").disabled = True
            document.getElementById("btnNext").innerText = "Installing..."
        Case 3
            document.getElementById("btnBack").style.display = "none"
            document.getElementById("btnNext").innerText = "Close"
            document.getElementById("btnNext").className = "btn btn-blue"
            document.getElementById("btnNext").disabled = False
    End Select
End Sub

Sub RunInstall()
    Dim vbsSrc, ps1Src, traySrc
    vbsSrc  = scriptDir & "\claude-remote.vbs"
    ps1Src  = scriptDir & "\claude-remote-start.ps1"
    traySrc = scriptDir & "\claude-remote-tray.ps1"

    ' Check source files exist
    If Not fso.FileExists(vbsSrc) Or Not fso.FileExists(ps1Src) Or Not fso.FileExists(traySrc) Then
        SetStatus "stFiles", "Source files missing", "fail"
        ShowAlert "alertInstall", "error", "Source files not found. Make sure all files are in the same folder as install.hta"
        document.getElementById("btnNext").disabled = False
        Exit Sub
    End If

    ' Create install folder
    On Error Resume Next
    If Not fso.FolderExists(installDir) Then fso.CreateFolder installDir

    ' Copy files
    fso.CopyFile vbsSrc,  installDir & "\claude-remote.vbs",       True
    fso.CopyFile ps1Src,  installDir & "\claude-remote-start.ps1", True
    fso.CopyFile traySrc, installDir & "\claude-remote-tray.ps1",  True

    If Err.Number <> 0 Then
        SetStatus "stFiles", "Error", "fail"
        ShowAlert "alertInstall", "error", "Failed to copy files: " & Err.Description
        document.getElementById("btnNext").disabled = False
        Exit Sub
    End If
    On Error GoTo 0

    SetStatus "stFiles", "Done", "ok"

    ' Patch paths in vbs
    Dim tsVbs, vbsContent
    Set tsVbs = fso.OpenTextFile(installDir & "\claude-remote.vbs", 1)
    vbsContent = tsVbs.ReadAll()
    tsVbs.Close
    vbsContent = Replace(vbsContent, "C:\Users\softlive", userHome)
    If slackWebhook <> "" Then
        vbsContent = Replace(vbsContent, "YOUR_SLACK_WEBHOOK_URL", slackWebhook)
    End If
    Set tsVbs = fso.CreateTextFile(installDir & "\claude-remote.vbs", True)
    tsVbs.Write vbsContent
    tsVbs.Close

    ' Patch paths in ps1
    Dim tsPs1, ps1Content
    Set tsPs1 = fso.OpenTextFile(installDir & "\claude-remote-start.ps1", 1)
    ps1Content = tsPs1.ReadAll()
    tsPs1.Close
    ps1Content = Replace(ps1Content, "C:\Users\softlive", userHome)
    Set tsPs1 = fso.CreateTextFile(installDir & "\claude-remote-start.ps1", True)
    tsPs1.Write ps1Content
    tsPs1.Close

    ' Startup shortcut
    Dim oShortcut
    Set oShortcut = WshShell.CreateShortcut(startupPath & "\claude-remote.lnk")
    oShortcut.TargetPath = installDir & "\claude-remote.vbs"
    oShortcut.WorkingDirectory = installDir
    oShortcut.Save
    SetStatus "stStartup", "Done", "ok"

    ' Slack
    If InStr(slackWebhook, "hooks.slack.com") > 0 Then
        SetStatus "stSlack", "Configured", "ok"
        document.getElementById("slackRow").style.display = "block"
    Else
        SetStatus "stSlack", "Skipped", "ok"
    End If

    document.getElementById("installPathLabel").innerText = installDir
    ShowScreen 3
End Sub

Sub SetStatus(elemId, txt, state)
    Dim el
    Set el = document.getElementById(elemId)
    el.innerText = txt
    If state = "ok" Then
        el.className = "check-status status-ok"
    ElseIf state = "fail" Then
        el.className = "check-status status-fail"
    ElseIf state = "wait" Then
        el.className = "check-status status-wait"
    End If
End Sub

Sub ShowAlert(elemId, alertType, msg)
    Dim el
    Set el = document.getElementById(elemId)
    el.className = "alert alert-" & alertType
    el.innerText = msg
End Sub

Sub openSlack()
    WshShell.Run "https://api.slack.com/apps"
End Sub
</script>

</body>
</html>
